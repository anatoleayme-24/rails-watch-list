<h1><%= @list.name %></h1>

<%= link_to "Add a movie", new_list_bookmark_path(@list) %>

<% @list.bookmarks.each do |bookmark| %>
  <p>
    <%= bookmark.movie.title %>
    <%= link_to "Remove", bookmark_path(bookmark), data: { turbo_method: :delete } %>
  </p>
<% end %>

<%= link_to "Back to lists", lists_path %>
