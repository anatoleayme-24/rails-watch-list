<%# BANNER - Movie of the Day %>
<div class="banner" style="background-image: url('<%= @movie_of_the_day.poster_url %>')">
  <div class="banner-overlay">
    <p class="banner-label">🎬 The Movie of the Day</p>
    <h1 class="banner-title"><%= @movie_of_the_day.title %></h1>
    <p class="banner-overview"><%= @movie_of_the_day.overview.truncate(200) %></p>
    <div class="banner-rating">⭐ <%= @movie_of_the_day.rating.round(1) %> / 10</div>
  </div>
</div>

<%# RANDOM SELECTION %>
<div class="section">
  <h2 class="section-title">🎲 Random Selection</h2>
  <div class="movies-grid">
    <% @random_movies.each do |movie| %>
      <div class="movie-card">
        <img src="<%= movie.poster_url %>" alt="<%= movie.title %>">
        <div class="movie-info">
          <p class="movie-title"><%= movie.title %></p>
          <p class="movie-rating">⭐ <%= movie.rating.round(1) %></p>
        </div>
      </div>
    <% end %>
  </div>
</div>
